{
  "name": "clef-search-worker",
  "version": "0.1.0",
  "description": "Clef Search Worker - hybrid BM25 + vector search via D1 FTS5 and Vectorize",
  "type": "module",
  "main": "dist/worker.js",
  "scripts": {
    "fable": "dotnet fable . --outDir dist/fable --noCache",
    "bundle": "esbuild dist/fable/src/Main.js --bundle --format=esm --outfile=dist/worker.js --minify",
    "build": "npm run fable && npm run bundle",
    "build:watch": "dotnet fable . --outDir dist/fable --watch",
    "dev": "npm run build && wrangler dev --remote",
    "dev:local": "npm run build && wrangler dev",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "wrangler": "^3.91.0"
  },
  "dependencies": {}
}
