&lt;thead&gt;
&lt;tr&gt;
&lt;th&gt;Tool&lt;/th&gt;
&lt;th&gt;Purpose&lt;/th&gt;
&lt;th&gt;CLI&lt;/th&gt;
&lt;/tr&gt;
&lt;/thead&gt;
&lt;tbody&gt;
&lt;tr&gt;
&lt;td&gt;&lt;strong&gt;Composer&lt;/strong&gt;&lt;/td&gt;
&lt;td&gt;Compiler and build orchestration&lt;/td&gt;
&lt;td&gt;&lt;code&gt;composer&lt;/code&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;&lt;strong&gt;ClefPak&lt;/strong&gt;&lt;/td&gt;
&lt;td&gt;Source-based package manager&lt;/td&gt;
&lt;td&gt;&lt;code&gt;clefpak&lt;/code&gt; / &lt;code&gt;cpk&lt;/code&gt;&lt;/td&gt;
